{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      ".read": false,
      ".write": false,
      "$roomId": {
        ".read": "auth != null && (root.child('rooms').child($roomId).child('invitees').hasChild(auth.uid) || root.child('rooms').child($roomId).child('players').hasChild(auth.uid))",
        ".write": "auth != null && (root.child('rooms').child($roomId).child('invitees').hasChild(auth.uid) || root.child('rooms').child($roomId).child('players').hasChild(auth.uid))",
        ".validate": "newData.hasChildren(['invitees', 'players', 'scores', 'gameType', 'deck', 'discard', 'turn'])",
        "invitees": {
          ".read": "auth != null && (root.child('rooms').child($roomId).child('invitees').hasChild(auth.uid) || root.child('rooms').child($roomId).child('players').hasChild(auth.uid))",
          ".write": false
        },
        "players": {
          ".read": "auth != null && (root.child('rooms').child($roomId).child('invitees').hasChild(auth.uid) || root.child('rooms').child($roomId).child('players').hasChild(auth.uid))",
          ".write": "auth != null && (root.child('rooms').child($roomId).child('invitees').hasChild(auth.uid) || root.child('rooms').child($roomId).child('players').hasChild(auth.uid))"
        },
        "$other": {
          ".read": "auth != null && (root.child('rooms').child($roomId).child('invitees').hasChild(auth.uid) || root.child('rooms').child($roomId).child('players').hasChild(auth.uid))",
          ".write": "auth != null && (root.child('rooms').child($roomId).child('invitees').hasChild(auth.uid) || root.child('rooms').child($roomId).child('players').hasChild(auth.uid))"
        }
      }
    },
    "training_corrections": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('reviewers').child(auth.uid).val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('reviewers').child(auth.uid).val() === true)"
      }
    },
    "reviewers": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && root.child('reviewers').child(auth.uid).val() === true"
      }
    },
    "history": {
      ".read": false,
      ".write": false,
      "$roomName": {
        ".read": "auth != null && (root.child('history').child($roomName).child('participants').hasChild(auth.uid))",
        ".write": "auth != null && (root.child('history').child($roomName).child('participants').hasChild(auth.uid))"
      }
    }
  }
}