{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "rooms": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$roomId": {
        "invitees": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    "training_corrections": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('reviewers').child(auth.uid).val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('reviewers').child(auth.uid).val() === true)"
      }
    },
    "reviewers": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && root.child('reviewers').child(auth.uid).val() === true"
      }
    },
    "history": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$roomName": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}